rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Files live at files/{uid}/{fileId}/{name} (see app.js). Only the owner
    // may read or write them. The previous `match /{allPaths=**}` rule let any
    // signed-in user read+write EVERY object in the bucket — removed.
    match /files/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Writes: owner only, capped at 100 MB per object to limit abuse.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (request.resource == null || request.resource.size < 100 * 1024 * 1024);
    }

    // Everything else denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
